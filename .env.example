# --- PostgreSQL (used by docker-compose & backend) ---
POSTGRES_USER=webgraph
POSTGRES_PASSWORD=webgraph
POSTGRES_DB=webgraph
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Set to "require" or "verify-full" in production
POSTGRES_SSLMODE=disable

# --- Backend ---
BACKEND_PORT=8080
# How many points of dummy history to seed (per metric, over the last hour)
SEED_POINTS_PER_METRIC=20000
# How many times per second the backend pushes new samples over WebSocket
PUSH_HZ=20
# How many log events per second the backend emits on /ws/logs
LOG_PUSH_HZ=30
# CORS allow-origin for REST + WS (comma separated)
ALLOWED_ORIGINS=http://localhost:3000

# --- Frontend (compiled into the JS bundle at build time) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
