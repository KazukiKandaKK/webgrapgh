{
  "name": "webgrapgh-cdk",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "webgrapgh-cdk": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "synth": "npx cdk synth",
