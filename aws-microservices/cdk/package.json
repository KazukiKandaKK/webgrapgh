  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "aws-cdk": "2.155.0",
    "aws-cdk-local": "2.18.0",
    "ts-node": "^10.9.2",
    "typescript": "5.5"
  },
  "dependencies": {
    "aws-cdk-lib": "2.155.0",
    "constructs": "10.3.0"
  }
}
