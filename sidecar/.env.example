# webgrapgh sidecar configuration
# Copy to .env and adjust as needed.

# Dashboard access (browser)
DASHBOARD_PORT=13000

# Backend API (internal; dashboard connects here)
BACKEND_PORT=18080

# Container metrics collection frequency (samples per second)
COLLECT_HZ=1

# PostgreSQL (internal storage; not exposed externally by default)
POSTGRES_PORT=15432
POSTGRES_USER=webgrapgh
POSTGRES_PASSWORD=webgrapgh
POSTGRES_DB=webgrapgh
